generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int         @id @default(autoincrement())
  name      String?     @db.VarChar(120)
  email     String?     @unique @db.VarChar(120)
  code      String      @unique @db.VarChar(100)
  password  String?     @db.VarChar(255)
  templates templates[]
  videos    Video[]

  @@map("users")
}

model Video {
  id           Int           @id @default(autoincrement())
  name         String        @db.VarChar(250)
  url          String        @db.VarChar(250)
  id_admin     Int?
  id_template  Int?
  type         Int?
  status       Int?
  states_video states_video? @relation(fields: [status], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "videos_states_video_FK")
  templates    templates?    @relation(fields: [id_template], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "videos_templates_FK")
  types_videos types_videos? @relation(fields: [type], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "videos_types_videos_FK")
  users        User?         @relation(fields: [id_admin], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "videos_users_FK")

  @@index([status], map: "videos_states_video_FK")
  @@index([id_template], map: "videos_templates_FK")
  @@index([type], map: "videos_types_videos_FK")
  @@index([id_admin], map: "videos_users_FK")
  @@map("videos")
}

model migrations {
  id        Int    @id @default(autoincrement())
  timestamp BigInt
  name      String @db.VarChar(255)
}

model sales {
  id          Int       @id @default(autoincrement())
  seller      String?   @db.VarChar(120)
  code_seller Int?
  date_seller DateTime? @default(now()) @db.Timestamp(0)
  company     String?   @db.VarChar(250)
  status      Boolean?  @default(true)
}

model states_video {
  id          Int     @id @default(autoincrement())
  name        String? @db.VarChar(120)
  description String? @db.VarChar(200)
  videos      Video[]
}

model templates {
  id        Int       @id @default(autoincrement())
  name      String?   @db.VarChar(120)
  content   String?   @db.Text
  create_at DateTime? @default(now()) @db.Timestamp(0)
  update_at DateTime? @default(now()) @db.Timestamp(0)
  id_admin  Int?
  users     User?     @relation(fields: [id_admin], references: [id], onDelete: Cascade, map: "templates_users_FK")
  videos    Video[]

  @@index([id_admin], map: "templates_users_FK")
}

model types_videos {
  id          Int     @id @default(autoincrement())
  name        String? @db.VarChar(150)
  description String? @db.VarChar(250)
  videos      Video[]
}
